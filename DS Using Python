from collections import deque

# Create queues
urgent_queue = deque()
priority_queue = deque()
normal_queue = deque()

# Add print job
def add_job():
    job = input("Enter document name: ")
    print("\nSelect Priority")
    print("1. Urgent")
    print("2. Priority")
    print("3. Normal")

    choice = int(input("Enter choice: "))

    if choice == 1:
        urgent_queue.append(job)
        print("Urgent print job added.")
    elif choice == 2:
        priority_queue.append(job)
        print("Priority print job added.")
    elif choice == 3:
        normal_queue.append(job)
        print("Normal print job added.")
    else:
        print("Invalid choice!")

# Print next job
def print_job():
    if urgent_queue:
        print("Printing Urgent:", urgent_queue.popleft())
    elif priority_queue:
        print("Printing Priority:", priority_queue.popleft())
    elif normal_queue:
        print("Printing Normal:", normal_queue.popleft())
    else:
        print("No print jobs available.")

# Display all jobs
def display_jobs():
    print("\nCurrent Print Queue")
    print("Urgent :", list(urgent_queue))
    print("Priority:", list(priority_queue))
    print("Normal :", list(normal_queue))

# Main Menu
while True:
    print("\n===== SMART PRINTER MENU =====")
    print("1. Add Print Job")
    print("2. Print Next Job")
    print("3. Display Queue")
    print("4. Exit")

    ch = int(input("Enter your choice: "))

    if ch == 1:
        add_job()
    elif ch == 2:
        print_job()
    elif ch == 3:
        display_jobs()
    elif ch == 4:
        print("Exiting...")
        break
    else:
        print("Invalid choice!")
